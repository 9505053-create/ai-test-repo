<Window x:Class="KeyboardVisualAssist.Overlay.ClipboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KVA Clipboard"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="Height" Width="420">

    <Border Background="#E0101010" CornerRadius="6" BorderBrush="#FF333333" BorderThickness="1" Padding="8,5">
        <DockPanel>
            <!-- 標題列 -->
            <DockPanel DockPanel.Dock="Top" Height="22" Margin="0,0,0,4"
                       MouseLeftButtonDown="OnDragStart">
                <TextBlock Text="📋 剪貼簿" Foreground="#FF888888" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- 自動更新指示燈 -->
                    <Ellipse x:Name="AutoDot" Width="7" Height="7" Margin="0,0,6,0"
                             Fill="#FF44BB44" ToolTip="自動監控中"/>
                    <TextBlock x:Name="UpdateTimeText" FontSize="9" Foreground="#FF555555"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button x:Name="CloseBtn" Content="✕" Click="OnClose"
                            Background="Transparent" Foreground="#FF666666"
                            BorderThickness="0" FontSize="11" Cursor="Hand" Padding="2,0"/>
                </StackPanel>
            </DockPanel>

            <!-- 剪貼簿內容 -->
            <TextBlock x:Name="ContentText"
                       Foreground="#FFEEEEEE"
                       FontSize="11" FontFamily="Microsoft JhengHei UI, Consolas"
                       TextWrapping="Wrap"
                       MaxHeight="80"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Top"/>
        </DockPanel>
    </Border>
</Window>
