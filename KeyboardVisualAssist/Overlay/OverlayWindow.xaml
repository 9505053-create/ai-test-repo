<Window x:Class="KeyboardVisualAssist.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KeyboardVisualAssist.Overlay"
        Title="KeyboardVisualAssist"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="920" Height="245"
        Left="20" Top="800"
        SizeToContent="Manual">

    <Window.Resources>

        <!-- ===== Converters ===== -->
        <local:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <local:RowToYConverter           x:Key="RowToYConverter"/>
        <local:ColToXConverter           x:Key="ColToXConverter"/>

        <!-- ===== 鍵盤按鍵 Border 樣式（備用，實際由 KeyButton 自管） ===== -->
        <Style x:Key="KeyStyle" TargetType="Border">
            <Setter Property="Background"       Value="#FF2D2D2D"/>
            <Setter Property="BorderBrush"      Value="#FF555555"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Margin"           Value="2"/>
            <Setter Property="MinWidth"         Value="36"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- ===== Layout 切換 / 控制按鈕樣式 ===== -->
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="#FF3A3A3A"/>
            <Setter Property="Foreground"   Value="#FFCCCCCC"/>
            <Setter Property="BorderBrush"  Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,3"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF00AAFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 高亮淡出 Storyboard（備用） ===== -->
        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.3"
                             Duration="0:0:0.5"
                             BeginTime="0:0:0.1"/>
        </Storyboard>

    </Window.Resources>

    <!-- 主容器：整個 overlay 可見性由此控制 -->
    <Border Background="{StaticResource OverlayBgBrush}"
            CornerRadius="8"
            Padding="10,8"
            Visibility="{Binding IsOverlayVisible, Converter={StaticResource BoolToVisConverter}}">

        <DockPanel>

            <!-- 頂部：標題列 + 控制按鈕 -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock Text="⌨ Keyboard Visual Assist"
                           Foreground="#FF888888"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Layout 切換按鈕 -->
                    <Button Content="{Binding CurrentLayoutLabel}"
                            Click="OnToggleLayout"
                            Style="{StaticResource ControlButtonStyle}"
                            ToolTip="切換 Standard / Hsu 排列"/>
                    <!-- 拖曳把手 -->
                    <Border Width="20" Height="20" Cursor="SizeAll"
                            MouseLeftButtonDown="OnDragStart"
                            Background="Transparent"
                            ToolTip="拖曳移動">
                        <TextBlock Text="⠿" Foreground="#FF888888"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </DockPanel>

            <!-- 最近按鍵顯示區（右側）-->
            <StackPanel DockPanel.Dock="Right" Width="140" Margin="8,0,0,0">
                <TextBlock Text="最近按鍵" Foreground="#FF888888"
                           FontSize="10" Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding RecentKeys}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="6,3"
                                    CornerRadius="4" HorizontalAlignment="Stretch">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FF3A3A3A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModifier}" Value="True">
                                                <Setter Property="Background" Value="#FF5A3A00"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Label}"
                                           Foreground="White"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- 鍵盤版面（主體）-->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="KeyboardPanel"
                              ItemsSource="{Binding LayoutEntries}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="720" Height="185"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:KeyButton DataContext="{Binding}"
                                             HighlightedKeys="{Binding DataContext.HighlightedKeyIds,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left"
                                    Value="{Binding Col, Converter={StaticResource ColToXConverter}}"/>
                            <Setter Property="Canvas.Top"
                                    Value="{Binding Row, Converter={StaticResource RowToYConverter}}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>
