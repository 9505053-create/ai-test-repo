<Window x:Class="KeyboardVisualAssist.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KeyboardVisualAssist.Overlay"
        Title="KeyboardVisualAssist"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="730" Height="260"
        SizeToContent="Manual">

    <Window.Resources>
        <!-- Converters -->
        <local:BoolToVisibilityConverter       x:Key="BoolToVisConverter"/>
        <local:FadeStateToBrushConverter       x:Key="FadeStateToBrushConv"/>
        <local:FadeStateToBorderBrushConverter x:Key="FadeStateToBorderConv"/>
        <local:RowToYConverter                 x:Key="RowToYConverter"/>
        <local:ColToXConverter                 x:Key="ColToXConverter"/>
        <local:WidthUnitToPixelConverter       x:Key="WidthUnitToPixelConv"/>
        <local:StringToVisibilityConverter     x:Key="StringToVisConv"/>

        <!-- 控制按鈕樣式 -->
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#FF3A3A3A"/>
            <Setter Property="Foreground"      Value="#FFAAAAAA"/>
            <Setter Property="BorderBrush"     Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="7,2"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF505050"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF00AAFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 整個 Overlay 可見性 -->
    <Border Background="#E0161616"
            CornerRadius="8"
            Padding="8,6"
            Visibility="{Binding IsOverlayVisible, Converter={StaticResource BoolToVisConverter}}">

        <DockPanel>

            <!-- ══ 頂部控制列（極細） ══ -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,5" Height="22">

                <!-- 標題（可拖曳區，Unlocked 時生效） -->
                <Border Cursor="SizeAll"
                        MouseLeftButtonDown="OnDragStart"
                        Background="Transparent"
                        ToolTip="Unlocked 時可拖曳移動">
                    <TextBlock Text="⌨ KVA"
                               Foreground="#FF666666"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="2,0,8,0"/>
                </Border>

                <!-- 右側按鈕群 -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <!-- Lock / Unlock -->
                    <Button Content="{Binding LockLabel}"
                            Click="OnToggleLock"
                            Style="{StaticResource ControlButtonStyle}"
                            Margin="0,0,4,0"
                            ToolTip="鎖定=click-through；解鎖=可拖曳"/>

                    <!-- Layout 切換 -->
                    <Button Content="{Binding CurrentLayoutLabel}"
                            Click="OnToggleLayout"
                            Style="{StaticResource ControlButtonStyle}"
                            Margin="0,0,4,0"
                            ToolTip="切換 Standard / Hsu 排列"/>

                    <!-- Compact / Full -->
                    <Button Content="{Binding ViewMode}"
                            Click="OnToggleView"
                            Style="{StaticResource ControlButtonStyle}"
                            Margin="0,0,0,0"
                            ToolTip="切換 Compact / Full 鍵盤範圍"/>
                </StackPanel>
            </DockPanel>

            <!-- ══ 底部最近按鍵（弱化輔助條） ══ -->
            <Border DockPanel.Dock="Bottom"
                    Height="22"
                    Margin="0,4,0,0"
                    Visibility="{Binding ShowRecentKeys, Converter={StaticResource BoolToVisConverter}}">
                <DockPanel>
                    <TextBlock Text="近："
                               Foreground="#FF555555"
                               FontSize="9"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <ItemsControl ItemsSource="{Binding RecentKeys}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,3,0" Padding="5,1"
                                        CornerRadius="3" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FF333333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsModifier}" Value="True">
                                                    <Setter Property="Background" Value="#FF4A3000"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="#FF888888"
                                               FontFamily="Consolas"
                                               FontSize="10"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- ══ 鍵盤主體（主視覺 ~85%） ══ -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding KeyCaps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="720" Height="195"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:KeyButton DataContext="{Binding}"
                                             Visibility="{Binding IsVisible,
                                                Converter={StaticResource BoolToVisConverter}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left"
                                    Value="{Binding Column, Converter={StaticResource ColToXConverter}}"/>
                            <Setter Property="Canvas.Top"
                                    Value="{Binding Row, Converter={StaticResource RowToYConverter}}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>
