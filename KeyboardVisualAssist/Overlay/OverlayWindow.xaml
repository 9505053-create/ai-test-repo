<Window x:Class="KeyboardVisualAssist.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KeyboardVisualAssist.Overlay"
        Title="KeyboardVisualAssist"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">

    <Window.Resources>
        <local:BoolToVisibilityConverter      x:Key="BoolToVisConverter"/>
        <local:RowToYConverter                x:Key="RowToYConverter"/>
        <local:ColToXConverter                x:Key="ColToXConverter"/>
        <local:StringToVisibilityConverter    x:Key="StringToVisConv"/>

        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Background"      Value="#FF3A3A3A"/>
            <Setter Property="Foreground"      Value="#FFAAAAAA"/>
            <Setter Property="BorderBrush"     Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF505050"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinBtn" TargetType="Button" BasedOn="{StaticResource CtrlBtn}">
            <Setter Property="Width"    Value="22"/>
            <Setter Property="Height"   Value="22"/>
            <Setter Property="Padding"  Value="0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="#E8161616"
            CornerRadius="8"
            Padding="8,5">
        <Border.LayoutTransform>
            <ScaleTransform ScaleX="{Binding WindowScale}" ScaleY="{Binding WindowScale}"/>
        </Border.LayoutTransform>

        <DockPanel>

            <!-- ══ 頂部標題列（按鈕區，不參與拖曳冒泡）══ -->
            <DockPanel DockPanel.Dock="Top" Height="26" Margin="0,0,0,4">

                <!-- 左：圖示（純裝飾）-->
                <TextBlock Text="⌨ KVA" Foreground="#FF555555" FontSize="10"
                           VerticalAlignment="Center" Margin="2,0,8,0"/>

                <!-- 右：所有按鈕，阻止冒泡到拖曳區 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            MouseLeftButtonDown="StopDragPropagation">
                    <Button Content="{Binding LabelModeLabel}" Click="OnCycleLabelMode"
                            Style="{StaticResource CtrlBtn}" Margin="0,0,2,0"
                            ToolTip="切換標籤：全/英/注/許/英+許"/>
                    <Button Content="{Binding LayoutLabel}" Click="OnToggleLayout"
                            Style="{StaticResource CtrlBtn}" Margin="0,0,2,0"
                            ToolTip="切換 Standard / Hsu"/>
                    <Button Content="{Binding ScaleLabel}" Click="OnCycleScale"
                            Style="{StaticResource CtrlBtn}" Margin="0,0,2,0"
                            ToolTip="切換大/中/小"/>
                    <Button Content="{Binding LockLabel}" Click="OnToggleLock"
                            Style="{StaticResource CtrlBtn}" Margin="0,0,2,0"
                            ToolTip="鎖定=穿透；解鎖=可互動"/>
                    <Button Content="⌫" Click="OnClearHighlight"
                            Style="{StaticResource CtrlBtn}" Margin="0,0,8,0"
                            ToolTip="清除高亮"/>
                    <Button Content="−" Click="OnMinimize"
                            Style="{StaticResource WinBtn}" Margin="0,0,2,0"
                            ToolTip="縮小/還原"/>
                    <Button Content="□" Click="OnToggleView"
                            Style="{StaticResource WinBtn}" Margin="0,0,2,0"
                            ToolTip="Compact/Full"/>
                    <Button Content="✕" Click="OnClose" Foreground="#FFFF7777"
                            Style="{StaticResource WinBtn}"
                            ToolTip="關閉"/>
                </StackPanel>
            </DockPanel>

            <!-- ══ 底部：拖曳 Grip Bar + 最近按鍵 ══ -->
            <Border DockPanel.Dock="Bottom"
                    Height="22" Margin="0,3,0,0"
                    Background="#22FFFFFF"
                    CornerRadius="0,0,6,6"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="OnDragStart"
                    ToolTip="拖曳此處移動視窗">
                <DockPanel>
                    <!-- 左：拖曳圖示提示 -->
                    <TextBlock Text="⠿" Foreground="#FF444444" FontSize="11"
                               VerticalAlignment="Center" Margin="4,0,6,0"/>
                    <TextBlock Text="近：" Foreground="#FF555555" FontSize="9"
                               VerticalAlignment="Center" Margin="0,0,4,0"
                               Visibility="{Binding ShowRecentKeys, Converter={StaticResource BoolToVisConverter}}"/>
                    <!-- 最近按鍵 -->
                    <ItemsControl ItemsSource="{Binding RecentKeys}"
                                  Visibility="{Binding ShowRecentKeys, Converter={StaticResource BoolToVisConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,3,0" Padding="5,1" CornerRadius="3" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FF333333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsModifier}" Value="True">
                                                    <Setter Property="Background" Value="#FF4A3000"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Label}" Foreground="#FF888888"
                                               FontFamily="Consolas" FontSize="10"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- 右：拖曳圖示 -->
                    <TextBlock Text="⠿" Foreground="#FF444444" FontSize="11"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               Margin="0,0,4,0"/>
                </DockPanel>
            </Border>

            <!-- ══ 鍵盤主體 ══ -->
            <ItemsControl ItemsSource="{Binding KeyCaps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="614" Height="195"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:KeyButton DataContext="{Binding}"
                                         Visibility="{Binding IsVisible,
                                            Converter={StaticResource BoolToVisConverter}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemContainerStyle>
                    <Style>
                        <Setter Property="Canvas.Left"
                                Value="{Binding Column, Converter={StaticResource ColToXConverter}}"/>
                        <Setter Property="Canvas.Top"
                                Value="{Binding Row, Converter={StaticResource RowToYConverter}}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>

        </DockPanel>
    </Border>
</Window>
