<UserControl x:Class="KeyboardVisualAssist.Overlay.KeyButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KeyboardVisualAssist.Overlay">

    <UserControl.Resources>
        <local:FadeStateToBrushConverter       x:Key="FadeStateToBrushConv"/>
        <local:FadeStateToBorderBrushConverter x:Key="FadeStateToBorderConv"/>
        <local:StringToVisibilityConverter     x:Key="StringToVisConv"/>
    </UserControl.Resources>

    <!-- 鍵帽本體 -->
    <Border x:Name="KeyBorder"
            Height="34"
            CornerRadius="4"
            Margin="1.5"
            BorderThickness="1">

        <!-- Background：由 FadeState + IsModifier 決定 -->
        <Border.Background>
            <MultiBinding Converter="{StaticResource FadeStateToBrushConv}">
                <Binding Path="DisplayFadeState"/>
                <Binding Path="IsModifier"/>
            </MultiBinding>
        </Border.Background>

        <!-- BorderBrush：Pressed/Fading 時加亮 -->
        <Border.BorderBrush>
            <Binding Path="DisplayFadeState" Converter="{StaticResource FadeStateToBorderConv}"/>
        </Border.BorderBrush>

        <Grid>
            <!-- SecondaryLabel：許氏符號（左上小字，僅 Hsu 模式有內容時顯示）-->
            <TextBlock Text="{Binding SecondaryLabel}"
                       Foreground="#FFCCAA00"
                       FontSize="8"
                       FontFamily="Microsoft JhengHei UI"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       Margin="3,2,0,0"
                       Visibility="{Binding SecondaryLabel, Converter={StaticResource StringToVisConv}}"/>

            <!-- PrimaryLabel：英文/鍵名（主要大字）-->
            <TextBlock x:Name="MainText"
                       Text="{Binding PrimaryLabel}"
                       Foreground="White"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
