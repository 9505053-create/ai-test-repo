<UserControl x:Class="KeyboardVisualAssist.Overlay.KeyButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="KeyBorder"
            Background="#FF2D2D2D"
            BorderBrush="#FF555555"
            BorderThickness="1"
            CornerRadius="4"
            Margin="1.5"
            Height="34">

        <!-- 寬度由 Code-behind 根據 WidthMultiplier 設定 -->

        <Grid>
            <!-- 許氏符號（左上小字）-->
            <TextBlock x:Name="HsuText"
                       Text="{Binding HsuLabel}"
                       Foreground="#FFCCAA00"
                       FontSize="9"
                       FontFamily="Microsoft JhengHei UI"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       Margin="3,2,0,0"
                       Visibility="Collapsed"/>

            <!-- 主顯示標籤（Standard 字母 / 數字）-->
            <TextBlock x:Name="MainText"
                       Text="{Binding StandardLabel}"
                       Foreground="White"
                       FontSize="11"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
